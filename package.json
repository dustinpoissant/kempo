{
  "name": "kempo",
  "version": "4.2.8",
  "type": "module",
  "description": "A fullstack CMS framework for creating websites with user authentication",
  "scripts": {
    "dev": "kempo-server --root app-public --port 9876",
    "build": "node scripts/build.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "makeAdmin": "node ./scripts/make-admin.js",
    "removeAdmin": "node ./scripts/removeAdmin.js",
    "test:email": "node ./scripts/test-email.js"
  },
  "author": "Dustin Poissant",
  "license": "MIT",
  "bin": {
    "kempo": "./bin/cli.js"
  },
  "files": [
    "bin",
    "dist",
    "app-public",
    "app-server",
    "app-drizzle.config.js",
    "server/utils",
    "server/db/index.js",
    "server/db/schema.js",
    "server/sdk.js",
    "middleware",
    "app-templates",
    "scripts/init-db.js"
  ],
  "dependencies": {
    "@lexical/history": "^0.42.0",
    "@lexical/html": "^0.42.0",
    "@lexical/list": "^0.42.0",
    "@lexical/rich-text": "^0.42.0",
    "@lexical/selection": "^0.42.0",
    "@lexical/utils": "^0.42.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.7",
    "drizzle-orm": "^0.44.7",
    "html-minifier-terser": "^7.2.0",
    "inquirer": "^12.6.1",
    "kempo": "^4.2.4",
    "kempo-server": "^3.1.0",
    "kempo-testing-framework": "^1.4.6",
    "kempo-ui": "^0.3.17",
    "lexical": "^0.42.0",
    "monaco-editor": "^0.55.1",
    "postgres": "^3.4.7",
    "resend": "^6.5.2",
    "terser": "^5.46.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dustinpoissant/kempo.git"
  },
  "bugs": {
    "url": "https://github.com/dustinpoissant/kempo/issues"
  },
  "homepage": "https://github.com/dustinpoissant/kempo#readme"
}
